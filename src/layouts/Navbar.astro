---
import { Picture } from "astro:assets";
import { getCollection } from "astro:content";
import { getSiteData } from "../data/siteData";
const siteData = await getSiteData();
import { PAYLOAD_URL } from "astro:env/client";

const navLinks = siteData.navigation;
---

<header class="w-full fixed z-10" transition:name="header">
    <div class="max-w-7xl mx-auto px-4">
        <div
            class="flex items-center justify-between md:grid md:grid-cols-[auto_1fr_auto] md:items-center gap-4 md:gap-6 py-4"
        >
            <div class="flex gap-20">
                <a
                    href="/#hero"
                    class="flex items-center"
                    aria-label="Dr Sheik Clinic home"
                    nav-button
                >
                    <img
                        src=`${PAYLOAD_URL}${siteData.logo_url}`
                        widths={[256]}
                        height={80}
                        alt="Dr Sheik Clinic logo"
                        class="h-20 object-contain"
                        loading="eager"
                        data-nav-logo-default
                    />
                    <img
                        src=`${PAYLOAD_URL}${siteData.logoAlt_url}`
                        width={256}
                        height={80}
                        alt="Dr Sheik Clinic logo"
                        class="h-20 object-contain hidden"
                        loading="eager"
                        data-nav-logo-alt
                    />
                </a>
            </div>

            <div class="flex items-center justify-end gap-3">
                <nav class="hidden md:flex justify-center" aria-label="Primary">
                    <ul
                        class="flex self-center items-center gap-12 text-md font-medium text-background rounded-lg py-4 px-8 w-auto bg-[#F5F9F4] transition-all duration-300"
                        data-nav-list
                    >
                        {
                            navLinks.map((nav) => (
                                <li>
                                    <a
                                        nav-button
                                        class="group relative py-1 transition-colors hover:text-primary"
                                        href={nav.url}
                                        data-nav-link
                                    >
                                        {nav.label}
                                        <span
                                            class="absolute left-0 -bottom-1 h-0.5 w-full origin-left scale-x-0 bg-primary transition-transform duration-200 ease-out group-hover:scale-x-100"
                                            aria-hidden="true"
                                            data-nav-link-underline
                                        />
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </nav>
            </div>
        </div>

        <div
            id="mobile-nav"
            class="md:hidden hidden flex-col gap-3 rounded-2xl border border-secondary/15 bg-white/90 p-4 shadow-lg backdrop-blur"
            data-menu-panel
        >
            <nav aria-label="Mobile primary">
                <ul class="flex flex-col gap-2 text-base font-medium text-secondary">
                    {
                        navLinks.map((link) => (
                            <li>
                                <a
                                    nav-button
                                    class="block rounded-lg px-5 py-2 transition hover:bg-primary/10 hover:text-primary text-center"
                                    href={link.href}
                                >
                                    {link.label}
                                </a>
                            </li>
                        ))
                    }
                    <a
                        href="/appointment"
                        class="inline-flex items-center justify-center rounded-full bg-primary px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-secondary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                        nav-button
                    >
                        Appointment
                    </a>
                </ul>
            </nav>
        </div>
    </div>
</header>
